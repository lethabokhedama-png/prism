{
  "name": "prism",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-provider AI orchestration platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web":      "bun run --cwd apps/web dev",
    "build:web":    "bun run --cwd apps/web build",
    "dev:gateway":  "bun run --cwd apps/gateway dev",
    "dev:compress": "bun run --cwd apps/compress dev",
    "typecheck":    "bun run --cwd apps/web typecheck",
    "lint":         "bun run --cwd apps/web lint"
  }
}
